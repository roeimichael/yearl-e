{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://yearl-e-backend-production.up.railway.app/api/:path*" },
    { "source": "/static/:path*", "destination": "/:path*" }
  ],
  "headers": [
    { "source": "/api/(.*)", "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(app.js|style.css)", "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }] }
  ]
}
